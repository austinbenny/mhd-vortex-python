\setlength{\parindent}{0pt}
\setlength{\parskip}{1em}

\newcommand{\hmwkTitle}{Homework Title}
\newcommand{\hmwkDate}{Date}
\newcommand{\hmwkClass}{Class Name}
\newcommand{\hmwkAuthorName}{Author Name}

\newcommand{\titleInfo}[4]{
    \renewcommand{\hmwkTitle}{#1}
    \renewcommand{\hmwkDate}{#2}
    \renewcommand{\hmwkClass}{#3}
    \renewcommand{\hmwkAuthorName}{#4}
}

\fancyhf{}
\lhead{\hmwkClass\ : \hmwkTitle}
\rhead{\hmwkAuthorName}
\rfoot{Page\ \thepage\ of\ \pageref{LastPage}}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0.4pt}

\newcommand{\makehomeworktitle}{
    \begin{titlepage}
        \centering
        \vspace*{2in}

        \hrule height 2pt
        \vspace{1.5em}

        {\Huge \textbf{\hmwkClass:\ \hmwkTitle} \par}

        \vspace{1.5em}

        {\Large \textbf{\hmwkAuthorName} \par}

        \vspace{2em}

        {\large \hmwkDate \par}

        \vspace{1.5em}
        \hrule height 2pt

        \vfill
    \end{titlepage}

    \pagestyle{fancy}
}

